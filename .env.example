# AD Web Console - Configuration
# Only these values needed - everything else auto-detected

PORT=4000
NODE_ENV=production
SESSION_SECRET=change-this-to-64-random-chars

# LDAP - auto-detected if not set
AD_HOST=ldap://127.0.0.1
AD_PORT=389
AD_BASE_DN=DC=yourdomain,DC=local
AD_DOMAIN_DISPLAY=yourdomain.local
AD_NETBIOS=YOURDOMAIN

# Service account - auto-created on first run if not set
AD_SERVICE_ACCOUNT=svc-adconsole@yourdomain.local
AD_SERVICE_PASSWORD=YourPassword

# Local fallback admin
LOCAL_ADMIN_USER=admin
LOCAL_ADMIN_PASS=Admin@Console2025!

# Admin groups (comma separated)
ADMIN_AD_GROUPS=Domain Admins,Administrators,IT-Admins

# ── HTTPS (optional, recommended for production) ──────────────────────
# Generate a self-signed cert for testing:
#   New-SelfSignedCertificate -DnsName "adconsole.yourdomain.local" -CertStoreLocation cert:\LocalMachine\My
#   Export to PEM via OpenSSL or use a proper CA-issued cert for production
# HTTPS_PORT=4443
# SSL_CERT_PATH=C:\ADWebConsole\certs\server.crt
# SSL_KEY_PATH=C:\ADWebConsole\certs\server.key
# HTTP_REDIRECT=true

# ── Auto-lock to OU (optional) ─────────────────────────────────────────
# AUTO_MOVE_LOCKED=true
# AD_LOCKED_OU=OU=Locked,DC=yourdomain,DC=local
