<!-- ── Notification Bell (fixed position, appears on every page) ────────── -->
<div id="notifBellWrap" style="position:fixed;top:12px;right:140px;z-index:300;display:flex;align-items:center;gap:8px;">
  <div class="notif-bell" onclick="toggleNotifPanel(event)" title="Notifications" id="notifBell">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
    <span class="notif-badge" id="notifBadge"></span>
  </div>
</div>

<!-- Notification Panel -->
<div class="notif-panel" id="notifPanel">
  <div class="notif-header">
    <div style="font-size:13px;font-weight:600;">Notifications & Activity</div>
    <div style="display:flex;gap:6px;align-items:center;">
      <span id="notifCount" style="font-size:11px;color:var(--text3);"></span>
      <button class="btn btn-secondary btn-sm" onclick="markAllRead()">Clear</button>
      <button onclick="toggleNotifPanel(event)" style="background:none;border:none;color:var(--text3);cursor:pointer;font-size:16px;line-height:1;">✕</button>
    </div>
  </div>
  <div class="notif-list" id="notifList">
    <div style="padding:24px;text-align:center;color:var(--text3);font-size:12px;">Loading notifications...</div>
  </div>
  <div style="padding:10px 16px;border-top:1px solid var(--border);text-align:center;flex-shrink:0;">
    <a href="/reports/audit" style="font-size:11px;color:var(--primary);">View full audit log →</a>
  </div>
</div>

<script>
var _notifOpen = false;
var _notifRead = parseInt(localStorage.getItem('notifReadCount')||'0');
var _notifLoaded = false;

function toggleNotifPanel(ev){
  if(ev) ev.stopPropagation();
  _notifOpen = !_notifOpen;
  document.getElementById('notifPanel').classList.toggle('open', _notifOpen);
  if(_notifOpen && !_notifLoaded){ loadNotifications(); _notifLoaded=true; }
}

document.addEventListener('click', function(e){
  if(_notifOpen && !document.getElementById('notifPanel').contains(e.target) && !document.getElementById('notifBell').contains(e.target)){
    _notifOpen=false;
    document.getElementById('notifPanel').classList.remove('open');
  }
});

var NOTIF_ICONS = {
  info:    '<span class="notif-dot notif-dot-info"></span>',
  success: '<span class="notif-dot notif-dot-success"></span>',
  warning: '<span class="notif-dot notif-dot-warning"></span>',
  danger:  '<span class="notif-dot notif-dot-danger"></span>',
};

function escN(s){ var d=document.createElement('div'); d.textContent=String(s||''); return d.innerHTML; }

function actionLabel(action){
  var map={
    USER_CREATED:'User Created',USER_MODIFIED:'User Modified',USER_DELETED:'User Deleted',
    USER_UNLOCKED:'Account Unlocked',USER_DISABLED:'User Disabled',USER_ENABLED:'User Enabled',
    USER_EXPORT:'Users Exported',USER_CREATED_BULK:'Bulk Import',
    GROUP_CREATED:'Group Created',GROUP_DELETED:'Group Deleted',
    GPO_CREATED:'GPO Created',GPO_DELETED:'GPO Deleted',GPO_BACKUP:'GPO Backup',GPO_RESTORE:'GPO Restore',
    OU_CREATED:'OU Created',OU_DELETED:'OU Deleted',
    LOGIN_FAILED:'Login Failed',LOGIN_BLOCKED:'Login Blocked (IP Banned)',
    BACKUP_COMPLETED:'Backup Completed',BACKUP_FAILED:'Backup Failed',
    CERT_EXPIRED:'Certificate Expired',CERT_EXPIRING:'Certificate Expiring Soon',
    SECURITY_FIX:'Security Fix Applied',SECURITY_RESCAN:'Security Rescan',
    CALENDAR_EVENT_ADDED:'Event Added',CALENDAR_EVENT_DELETED:'Event Deleted',
    IP_BANNED:'IP Address Banned',
  };
  return map[action] || action.replace(/_/g,' ');
}

async function loadNotifications(){
  try{
    var r = await fetch('/dashboard/api/notifications');
    var d = await r.json();
    if(!d.ok){ document.getElementById('notifList').innerHTML='<div style="padding:20px;text-align:center;color:var(--text3);font-size:12px;">Could not load notifications</div>'; return; }
    var notifs = d.notifications || [];
    var countEl = document.getElementById('notifCount');
    var badge = document.getElementById('notifBadge');
    var unread = Math.max(0, notifs.length - _notifRead);
    countEl.textContent = notifs.length + ' item' + (notifs.length!==1?'s':'');
    badge.className = 'notif-badge' + (unread>0?' show':'');

    if(!notifs.length){
      document.getElementById('notifList').innerHTML='<div style="padding:24px;text-align:center;"><div style="font-size:28px;margin-bottom:8px;">🔔</div><div style="font-size:12px;color:var(--text3);">No recent activity</div></div>';
      return;
    }

    var html = '';
    notifs.forEach(function(n){
      var icon = NOTIF_ICONS[n.type] || NOTIF_ICONS.info;
      var detail = n.target ? (' — ' + n.target) : '';
      html += '<div class="notif-item">' +
        icon +
        '<div style="flex:1;min-width:0;">' +
          '<div style="font-size:12px;font-weight:500;">' + escN(actionLabel(n.action)) + '</div>' +
          '<div style="font-size:11px;color:var(--text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + escN(n.actor) + escN(detail) + '</div>' +
          (n.details?'<div style="font-size:10px;color:var(--text4);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+escN(n.details)+'</div>':'') +
        '</div>' +
        '<div style="font-size:10px;color:var(--text4);white-space:nowrap;margin-left:6px;">' + escN(n.timeAgo) + '</div>' +
        '</div>';
    });
    document.getElementById('notifList').innerHTML = html;
  }catch(e){
    document.getElementById('notifList').innerHTML='<div style="padding:20px;text-align:center;color:var(--danger);font-size:12px;">Error: '+e.message+'</div>';
  }
}

function markAllRead(){
  var notifList = document.getElementById('notifList');
  _notifRead = parseInt(document.getElementById('notifCount').textContent)||0;
  localStorage.setItem('notifReadCount', _notifRead);
  document.getElementById('notifBadge').className='notif-badge';
  toggleNotifPanel();
}

// Check for new notifications every 60s (update badge count only, don't reload panel)
setInterval(async function(){
  if(_notifOpen) return; // don't re-fetch if panel is already open
  try{
    var r=await fetch('/dashboard/api/notifications');
    var d=await r.json();
    if(d.ok){
      var count=(d.notifications||[]).length;
      var unread=Math.max(0,count-_notifRead);
      document.getElementById('notifBadge').className='notif-badge'+(unread>0?' show':'');
    }
  }catch(e){}
}, 60000);
</script>

<div class="main">
