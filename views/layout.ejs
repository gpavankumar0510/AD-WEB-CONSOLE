<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title><%- typeof title !== 'undefined' ? title : 'AD Console' %> | AD Web Console</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#070a0f;--surface:#0d1117;--surface2:#161b27;--surface3:#1e2535;--surface4:#252d3d;
  --border:#1e2535;--border2:#2a3348;--border3:#344260;
  --primary:#4f8ef7;--primary-dark:#3a75e0;--primary-glow:rgba(79,142,247,.15);--primary-bright:rgba(79,142,247,.35);
  --success:#10b981;--success-bg:rgba(16,185,129,.1);--success-glow:rgba(16,185,129,.2);
  --warning:#f59e0b;--warning-bg:rgba(245,158,11,.1);--warning-glow:rgba(245,158,11,.2);
  --danger:#ef4444;--danger-bg:rgba(239,68,68,.1);--danger-glow:rgba(239,68,68,.2);
  --info:#60a5fa;--info-bg:rgba(96,165,250,.1);
  --purple:#a78bfa;--purple-bg:rgba(167,139,250,.1);
  --cyan:#22d3ee;--cyan-bg:rgba(34,211,238,.1);
  --text:#f1f5f9;--text2:#94a3b8;--text3:#475569;--text4:#334155;
  --mono:'JetBrains Mono',monospace;--sans:'Inter',system-ui,sans-serif;
  --radius:8px;--radius-lg:12px;--radius-xl:16px;
  --shadow:0 4px 24px rgba(0,0,0,.4);--shadow-lg:0 8px 48px rgba(0,0,0,.5);
  --transition:all .2s cubic-bezier(.4,0,.2,1);
}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;display:flex;line-height:1.6;font-size:14px;}
a{color:inherit;text-decoration:none;}

/* Sidebar */
.sidebar{width:224px;min-width:224px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;height:100vh;position:sticky;top:0;overflow-y:auto;overflow-x:hidden;}
.sidebar::-webkit-scrollbar{width:4px;}.sidebar::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.sidebar-brand{padding:16px 14px;border-bottom:1px solid var(--border);}
.brand-logo{display:flex;align-items:center;gap:10px;margin-bottom:4px;}
.brand-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--primary),#6366f1);border-radius:9px;display:flex;align-items:center;justify-content:center;box-shadow:0 0 16px var(--primary-glow);flex-shrink:0;}
.brand-icon svg{width:16px;height:16px;fill:white;}
.brand-name{font-size:14px;font-weight:700;letter-spacing:-.02em;background:linear-gradient(135deg,#fff,#94a3b8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.brand-domain{font-size:10px;color:var(--text3);font-family:var(--mono);background:var(--surface2);padding:2px 7px;border-radius:4px;border:1px solid var(--border);display:inline-block;}
.sidebar-nav{flex:1;padding:6px 0;}
.nav-section{padding:12px 14px 4px;font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text4);}
.nav-item{display:flex;align-items:center;gap:9px;padding:7px 14px;font-size:12px;font-weight:500;color:var(--text3);cursor:pointer;border-left:2px solid transparent;transition:var(--transition);position:relative;margin:1px 0;}
.nav-item:hover{background:var(--surface2);color:var(--text2);border-left-color:var(--border3);}
.nav-item.active{background:var(--primary-glow);color:var(--primary);border-left-color:var(--primary);}
.nav-item.active::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--primary);box-shadow:0 0 8px var(--primary);}
.nav-item svg{width:14px;height:14px;flex-shrink:0;opacity:.8;}
.nav-item.active svg{opacity:1;}
.nav-badge{margin-left:auto;font-size:9px;padding:1px 5px;border-radius:8px;font-weight:700;}
.badge-danger-nav{background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-glow);}
.sidebar-footer{padding:10px 14px;border-top:1px solid var(--border);}
.admin-info{display:flex;align-items:center;gap:8px;}
.admin-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--primary),#6366f1);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;box-shadow:0 0 10px var(--primary-glow);}
.admin-avatar.user-av{background:linear-gradient(135deg,var(--success),#059669);}
.admin-details .aname{font-size:11px;font-weight:600;}
.admin-details .arole{font-size:10px;color:var(--text3);}
.role-pill{font-size:9px;padding:1px 5px;border-radius:6px;font-weight:600;margin-left:3px;}
.role-pill.admin{background:var(--warning-bg);color:var(--warning);border:1px solid var(--warning-glow);}
.role-pill.user{background:var(--success-bg);color:var(--success);border:1px solid var(--success-glow);}
.logout-btn{margin-left:auto;color:var(--text3);padding:4px;border-radius:6px;transition:var(--transition);}
.logout-btn:hover{color:var(--danger);background:var(--danger-bg);}
.logout-btn svg{width:13px;height:13px;}

/* Main */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}
.topbar{height:52px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:12px;flex-shrink:0;backdrop-filter:blur(12px);}
.topbar-title{font-size:15px;font-weight:700;letter-spacing:-.02em;}
.topbar-sub{font-size:11px;color:var(--text3);}
.topbar-actions{margin-left:auto;display:flex;align-items:center;gap:6px;}
.content{flex:1;overflow-y:auto;padding:20px;}
.content::-webkit-scrollbar{width:6px;}.content::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}

/* Cards */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;transition:var(--transition);}
.card:hover{border-color:var(--border2);}
.card-header{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:9px;background:var(--surface2);}
.card-title{font-size:12px;font-weight:600;letter-spacing:-.01em;}
.card-header-actions{margin-left:auto;display:flex;gap:5px;align-items:center;}
/* Notification bell */
.notif-bell{position:relative;cursor:pointer;padding:6px;border-radius:8px;display:flex;align-items:center;color:var(--text2);transition:var(--transition);}
.notif-bell:hover{background:var(--surface3);color:var(--text);}
.notif-badge{position:absolute;top:2px;right:2px;width:8px;height:8px;background:var(--danger);border-radius:50%;display:none;}
.notif-badge.show{display:block;}
.notif-panel{display:none;position:fixed;top:52px;right:16px;width:380px;max-height:520px;background:var(--surface);border:1px solid var(--border2);border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,.4);z-index:400;flex-direction:column;}
.notif-panel.open{display:flex;}
.notif-header{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.notif-list{overflow-y:auto;flex:1;}
.notif-item{display:flex;gap:10px;padding:10px 16px;border-bottom:1px solid var(--border);cursor:default;}
.notif-item:hover{background:var(--surface2);}
.notif-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.notif-dot-info{background:var(--info);}
.notif-dot-success{background:var(--success);}
.notif-dot-warning{background:var(--warning);}
.notif-dot-danger{background:var(--danger);}
.card-body{padding:0;}

/* Stats */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin-bottom:20px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;position:relative;overflow:hidden;transition:var(--transition);}
.stat-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .3s;}
.stat-card:hover{border-color:var(--border2);transform:translateY(-1px);}
.stat-card:hover::before{opacity:1;}
.stat-card.danger::before{background:radial-gradient(circle at 100% 0,var(--danger-glow),transparent 60%);}
.stat-card.success::before{background:radial-gradient(circle at 100% 0,var(--success-glow),transparent 60%);}
.stat-card.warning::before{background:radial-gradient(circle at 100% 0,var(--warning-glow),transparent 60%);}
.stat-card.info::before{background:radial-gradient(circle at 100% 0,var(--primary-glow),transparent 60%);}
.stat-card.purple::before{background:radial-gradient(circle at 100% 0,rgba(167,139,250,.2),transparent 60%);}
.stat-label{font-size:10px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;}
.stat-value{font-size:28px;font-weight:300;line-height:1;margin-bottom:3px;font-variant-numeric:tabular-nums;}
.stat-sub{font-size:10px;color:var(--text3);}
.stat-card.danger .stat-value{color:var(--danger);}
.stat-card.success .stat-value{color:var(--success);}
.stat-card.warning .stat-value{color:var(--warning);}
.stat-card.info .stat-value{color:var(--primary);}
.stat-card.purple .stat-value{color:var(--purple);}
.stat-card.cyan .stat-value{color:var(--cyan);}

/* Table */
table{width:100%;border-collapse:collapse;}
thead th{padding:9px 12px;font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border);text-align:left;background:var(--surface2);}
tbody tr{border-bottom:1px solid var(--border);transition:background .12s;}
tbody tr:hover{background:var(--surface2);}
tbody tr:last-child{border-bottom:none;}
td{padding:9px 12px;font-size:12px;}

/* Badges */
.badge{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:2px 8px;border-radius:20px;font-weight:600;letter-spacing:.01em;}
.badge-active{background:var(--success-bg);color:var(--success);border:1px solid var(--success-glow);}
.badge-disabled{background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-glow);}
.badge-locked{background:var(--warning-bg);color:var(--warning);border:1px solid var(--warning-glow);}
.badge-warned{background:var(--warning-bg);color:var(--warning);border:1px solid var(--warning-glow);}
.badge-info{background:var(--info-bg);color:var(--info);border:1px solid rgba(96,165,250,.2);}
.badge-neutral{background:var(--surface3);color:var(--text2);border:1px solid var(--border2);}
.badge-purple{background:var(--purple-bg);color:var(--purple);border:1px solid rgba(167,139,250,.2);}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:5px;padding:6px 13px;border-radius:var(--radius);font-size:12px;font-weight:600;font-family:var(--sans);cursor:pointer;border:1px solid transparent;transition:var(--transition);line-height:1;text-decoration:none;letter-spacing:-.01em;}
.btn:disabled{opacity:.45;cursor:not-allowed;}
.btn-primary{background:var(--primary);color:#fff;border-color:var(--primary);box-shadow:0 0 16px var(--primary-glow);}
.btn-primary:hover:not(:disabled){background:var(--primary-dark);box-shadow:0 0 24px var(--primary-bright);}
.btn-secondary{background:var(--surface2);color:var(--text2);border-color:var(--border2);}
.btn-secondary:hover{background:var(--surface3);color:var(--text);border-color:var(--border3);}
.btn-danger{background:var(--danger-bg);color:var(--danger);border-color:rgba(239,68,68,.3);}
.btn-danger:hover{background:var(--danger);color:#fff;box-shadow:0 0 16px var(--danger-glow);}
.btn-success{background:var(--success-bg);color:var(--success);border-color:rgba(16,185,129,.3);}
.btn-success:hover{background:var(--success);color:#000;box-shadow:0 0 16px var(--success-glow);}
.btn-warning{background:var(--warning-bg);color:var(--warning);border-color:rgba(245,158,11,.3);}
.btn-warning:hover{background:var(--warning);color:#000;}
.btn-sm{padding:4px 9px;font-size:11px;}
.btn svg{width:12px;height:12px;flex-shrink:0;}

/* Inputs */
input[type=text],input[type=email],input[type=password],input[type=search],input[type=number],select,textarea{
  width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius);
  color:var(--text);font-family:var(--sans);font-size:13px;padding:8px 11px;outline:none;transition:var(--transition);
}
input:focus,select:focus,textarea:focus{border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-glow);}
select option{background:var(--surface2);}
label{font-size:12px;font-weight:600;color:var(--text2);display:block;margin-bottom:5px;letter-spacing:-.01em;}
.form-group{margin-bottom:14px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-hint{font-size:11px;color:var(--text3);margin-top:3px;}

/* Alerts */
.alert{padding:10px 14px;border-radius:var(--radius);font-size:12px;display:flex;align-items:flex-start;gap:9px;margin-bottom:14px;border:1px solid;}
.alert-success{background:var(--success-bg);color:var(--success);border-color:rgba(16,185,129,.3);}
.alert-error{background:var(--danger-bg);color:var(--danger);border-color:rgba(239,68,68,.3);}
.alert-warning{background:var(--warning-bg);color:var(--warning);border-color:rgba(245,158,11,.3);}
.alert-info{background:var(--info-bg);color:var(--info);border-color:rgba(96,165,250,.3);}

/* Search */
.search-box{position:relative;}
.search-box svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:13px;height:13px;color:var(--text3);pointer-events:none;}
.search-box input{padding-left:30px;}

/* Empty state */
.empty-state{padding:48px;text-align:center;color:var(--text3);}
.empty-state svg{width:40px;height:40px;margin:0 auto 12px;opacity:.4;}
.empty-state p{font-size:13px;}

/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;animation:fadeIn .15s ease;}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius-xl);width:100%;max-width:480px;max-height:90vh;overflow-y:auto;box-shadow:var(--shadow-lg);}
.modal-header{padding:14px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.modal-title{font-size:14px;font-weight:700;}
.modal-body{padding:18px;}
.modal-footer{padding:12px 18px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:6px;}

/* Misc */
.mono{font-family:var(--mono);font-size:11px;}
.text-muted{color:var(--text3);}
.text-success{color:var(--success);}
.text-danger{color:var(--danger);}
.truncate{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.settings-row{display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border);}
.settings-row:last-child{border-bottom:none;}

/* Progress bar */
.progress-outer{height:6px;background:var(--border2);border-radius:3px;overflow:hidden;}
.progress-inner{height:100%;border-radius:3px;transition:width .5s ease;}

/* Glow text */
.glow-text{text-shadow:0 0 20px currentColor;}

/* Animations */
@keyframes fadeIn{from{opacity:0;transform:scale(.97)}to{opacity:1;transform:scale(1)}}
@keyframes slideUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.animate-fade{animation:fadeIn .3s ease both;}
.animate-slide{animation:slideUp .4s cubic-bezier(.4,0,.2,1) both;}

/* SCAP score ring */
.scap-ring{position:relative;display:inline-flex;align-items:center;justify-content:center;}
.scap-ring svg{transform:rotate(-90deg);}
.scap-ring-text{position:absolute;text-align:center;}

/* DC status dot */
.dc-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.dc-dot.online{background:var(--success);box-shadow:0 0 6px var(--success);}
.dc-dot.offline{background:var(--danger);box-shadow:0 0 6px var(--danger);}

/* Live clock */
#live-clock{font-family:var(--mono);font-size:11px;color:var(--text3);background:var(--surface2);padding:3px 8px;border-radius:5px;border:1px solid var(--border);}
</style>
</head>
<body>
<% var isAdmin = admin && admin.role === 'admin'; %>
<% var recycleBinCount = 0; try { recycleBinCount = require('../utils/recycleBin').getAll().length; } catch(e) {} %>
<% var domainLabel = ''; try { domainLabel = require('../utils/autoDetect').getSettings().domain || 'domain.local'; } catch(e) { domainLabel = process.env.AD_DOMAIN_DISPLAY || 'domain.local'; } %>

<nav class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-logo">
      <div class="brand-icon"><svg viewBox="0 0 20 20"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2zm0 6a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2z"/></svg></div>
      <div class="brand-name">AD Console</div>
    </div>
    <div class="brand-domain"><%= domainLabel %></div>
  </div>
  <div class="sidebar-nav">
    <div class="nav-section">Overview</div>
    <a href="/dashboard" class="nav-item <%= page==='dashboard'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <% if (isAdmin) { %>
    <a href="/security" class="nav-item <%= page==='security'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Security Recommendations
    </a>
    <div class="nav-section">Identity</div>
    <a href="/users" class="nav-item <%= page==='users'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
      Users
    </a>
    <a href="/users/locked" class="nav-item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      Locked Accounts
    </a>
    <a href="/groups" class="nav-item <%= page==='groups'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/></svg>
      Groups
    </a>
    <a href="/computers" class="nav-item <%= page==='computers'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      Computers
    </a>
    <a href="/ous" class="nav-item <%= page==='ous'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
      OUs
    </a>
    <div class="nav-section">Policy</div>
    <a href="/gpo" class="nav-item <%= page==='gpo'&&(typeof subpage==='undefined'||subpage!=='templates')?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Group Policies
    </a>

    <div class="nav-section">Operations</div>
    <a href="/backup" class="nav-item <%= page==='backup'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
      Backup
    </a>
    <a href="/services" class="nav-item <%= page==='services'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
      AD Services
    </a>
    <a href="/migration" class="nav-item <%= page==='migration'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      DC Migration
    </a>
    <a href="/recycle" class="nav-item <%= page==='recycle'?'active':'' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
      Recycle Bin
