<%- include('../layout', { title: 'GPO Templates', page: 'gpo', admin }) %>
<div class="topbar"><div><div class="topbar-title">GPO Templates</div><div class="topbar-sub">Pre-built security policy baselines</div></div><div class="topbar-actions"><a href="/gpo" class="btn btn-secondary">Back to Policies</a></div></div>
<div class="content">
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:14px;">
<% for(var i=0;i<templates.length;i++){var t=templates[i];%>
<div class="card" style="transition:border-color .15s;" onmouseover="this.style.borderColor='var(--primary)'" onmouseout="this.style.borderColor='var(--border)'">
  <div class="card-body" style="padding:16px;">
    <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);margin-bottom:6px;"><%= t.category %></div>
    <div style="font-size:14px;font-weight:600;margin-bottom:6px;"><%= t.name %></div>
    <div style="font-size:12px;color:var(--text2);margin-bottom:12px;"><%= t.description %></div>
    <div style="font-size:11px;color:var(--text3);margin-bottom:12px;"><%= (t.settings||[]).length %> setting(s)</div>
    <button class="btn btn-primary btn-sm" style="width:100%;" onclick="applyTemplate('<%= t.id %>','<%= t.name.replace(/'/g,String.fromCharCode(39)) %>')">Apply This Template</button>
  </div>
</div>
<%}%></div></div>

<div class="modal-overlay" id="templateModal"><div class="modal"><div class="modal-header"><span class="modal-title" id="templateModalTitle">Apply Template</span><button class="btn btn-secondary btn-sm" onclick="closeTpl()">✕</button></div>
<div class="modal-body"><div class="form-group"><label>Policy Name</label><input type="text" id="tplName"/></div><div class="form-group"><label>Description</label><input type="text" id="tplDesc"/></div></div>
<div class="modal-footer"><button class="btn btn-secondary" onclick="closeTpl()">Cancel</button><button class="btn btn-primary" id="tplSubmitBtn" onclick="submitTemplate()">Create Policy</button></div>
</div></div>

<script>
var currentTplId='';
function applyTemplate(id,name){currentTplId=id;document.getElementById('tplName').value=name;document.getElementById('tplDesc').value='';document.getElementById('templateModal').classList.add('open');}
function closeTpl(){document.getElementById('templateModal').classList.remove('open');}
function submitTemplate(){var name=document.getElementById('tplName').value.trim();if(!name){alert('Enter a name');return;}var form=document.createElement('form');form.method='POST';form.action='/gpo/from-template/'+currentTplId;var n=document.createElement('input');n.name='name';n.value=name;form.appendChild(n);var d=document.createElement('input');d.name='description';d.value=document.getElementById('tplDesc').value;form.appendChild(d);document.body.appendChild(form);form.submit();}
document.getElementById('templateModal').addEventListener('click',function(e){if(e.target===this)closeTpl();});
</script>
<%- include('../layout-end') %>