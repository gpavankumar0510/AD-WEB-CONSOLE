<%- include('../layout', { title: 'Password Expiry', page: 'reports', admin }) %>
<div class="topbar"><div><div class="topbar-title">Password Expiry Report</div><div class="topbar-sub">Domain password policy: max age <%= data.maxPasswordAgeDays || 'N/A' %> days</div></div>
<div class="topbar-actions"><a href="/reports/export/password-expiry" class="btn btn-primary">Export CSV</a><a href="/reports" class="btn btn-secondary">Back</a></div></div>
<div class="content">
<% if(error){%><div class="alert alert-error"><%= error %></div><%}%>
<% var users2=data.users||[];
var expired=users2.filter(function(u){return u.enabled&&!u.neverExpires&&(u.daysUntilExpiry||0)<=0;});
var expiring7=users2.filter(function(u){return u.enabled&&!u.neverExpires&&(u.daysUntilExpiry||0)>0&&(u.daysUntilExpiry||0)<=7;});
var expiring30=users2.filter(function(u){return u.enabled&&!u.neverExpires&&(u.daysUntilExpiry||0)>7&&(u.daysUntilExpiry||0)<=30;});
var neverExpires=users2.filter(function(u){return u.neverExpires;});
%>
<div class="stat-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:14px;">
  <div class="stat-card danger"><div class="stat-label">Expired</div><div class="stat-value"><%= expired.length %></div><div class="stat-sub">Password expired</div></div>
  <div class="stat-card warning"><div class="stat-label">Expiring in 7 days</div><div class="stat-value"><%= expiring7.length %></div></div>
  <div class="stat-card info"><div class="stat-label">Expiring in 30 days</div><div class="stat-value"><%= expiring30.length %></div></div>
  <div class="stat-card"><div class="stat-label">Never Expires</div><div class="stat-value" style="color:var(--text)"><%= neverExpires.length %></div></div>
</div>
<div class="card"><div class="card-header"><span class="card-title">All Users Password Status</span></div><div class="card-body">
<table><thead><tr><th>Username</th><th>Display Name</th><th>Last Changed</th><th>Expires</th><th>Days Left</th><th>Status</th></tr></thead><tbody>
<% var sorted=users2.filter(function(u){return u.enabled;}).sort(function(a,b){return (a.daysUntilExpiry||9999)-(b.daysUntilExpiry||9999);});%>
<% for(var i=0;i<sorted.length;i++){var u=sorted[i];
var dLeft=u.daysUntilExpiry;
var statusBadge=u.neverExpires?'badge-neutral':dLeft===null?'badge-neutral':(dLeft||0)<=0?'badge-disabled':(dLeft||0)<=7?'badge-locked':'badge-active';
var statusText=u.neverExpires?'Never Expires':dLeft===null?'N/A':(dLeft||0)<=0?'Expired':(dLeft||0)+' days';
%>
<tr>
  <td class="mono" style="font-size:12px;"><%= u.username %></td>
  <td style="font-size:12px;font-weight:500;"><%= u.displayName||'—' %></td>
  <td class="text-muted" style="font-size:11px;"><%= u.passwordLastSet?new Date(u.passwordLastSet).toLocaleDateString('en-GB'):'Never' %></td>
  <td class="text-muted" style="font-size:11px;"><%= u.passwordExpiry?new Date(u.passwordExpiry).toLocaleDateString('en-GB'):'—' %></td>
  <td style="font-size:12px;font-weight:500;color:<%= (dLeft||0)<=0&&!u.neverExpires?'var(--danger)':(dLeft||0)<=7?'var(--warning)':'var(--text)' %>"><%= statusText %></td>
  <td><span class="badge <%= statusBadge %>" style="font-size:10px;"><%= (dLeft||0)<=0&&!u.neverExpires?'Expired':u.neverExpires?'Never':'OK' %></span></td>
</tr>
<%}%>
</tbody></table>
</div></div></div>
<%- include('../layout-end') %>