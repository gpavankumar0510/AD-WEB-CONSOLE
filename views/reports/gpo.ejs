<%- include('../layout', { title: 'Group Policy Report', page: 'reports', admin }) %>
<div class="topbar"><div><div class="topbar-title">Group Policy Report</div><div class="topbar-sub"><%= policies.length %> policies in console</div></div>
<div class="topbar-actions"><a href="/reports/export/gpo" class="btn btn-primary">Export CSV</a><a href="/gpo" class="btn btn-secondary">Manage GPOs</a><a href="/reports" class="btn btn-secondary">Back</a></div></div>
<div class="content">
<% if(error){%><div class="alert alert-error"><%= error %></div><%}%>
<div class="card"><div class="card-body">
<% if(!policies.length){%><div class="empty-state" style="padding:24px;"><p>No GPOs found</p></div>
<%}else{%>
<table><thead><tr><th>Name</th><th>Category</th><th>Status</th><th>Settings</th><th>Source</th><th>Created</th></tr></thead><tbody>
<% for(var i=0;i<policies.length;i++){var p=policies[i];%>
<tr>
  <td style="font-size:12px;font-weight:500;"><a href="/gpo/<%= p.id %>" style="color:var(--text);"><%= p.name %></a></td>
  <td class="text-muted" style="font-size:11px;"><%= p.category||'Custom' %></td>
  <td><span class="badge <%= p.status==='Active'?'badge-active':'badge-disabled' %>"><%= p.status||'Active' %></span></td>
  <td style="font-size:12px;"><%= (p.settings||[]).length %></td>
  <td><span class="badge <%= p.adGpoId?'badge-info':'badge-purple' %>" style="font-size:10px;"><%= p.adGpoId?'AD Synced':'Custom' %></span></td>
  <td class="text-muted" style="font-size:11px;"><%= new Date(p.createdAt).toLocaleDateString('en-GB') %></td>
</tr>
<%}%>
</tbody></table>
<%}%>
</div></div></div>
<%- include('../layout-end') %>