<%- include('../layout', { title: 'Security Report', page: 'reports', admin }) %>
<div class="topbar"><div><div class="topbar-title">Security Report</div><div class="topbar-sub">Executive security summary</div></div>
<div class="topbar-actions"><a href="/reports/export/security" class="btn btn-primary">Export CSV</a><a href="/reports" class="btn btn-secondary">Back</a></div></div>
<div class="content">
<% if(error){%><div class="alert alert-error"><%= error %></div><%}%>
<div class="stat-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:16px;">
  <div class="stat-card <%= scap&&scap.grade==='A'?'success':scap&&(scap.grade==='B')?'info':'warning' %>">
    <div class="stat-label">SCAP Security Score</div>
    <div class="stat-value" style="font-size:20px;"><%= scap?scap.percent+'% ('+scap.grade+')':'—' %></div>
  </div>
  <div class="stat-card <%= failedLogins>10?'danger':'success' %>"><div class="stat-label">Failed Logins (recent)</div><div class="stat-value"><%= failedLogins %></div></div>
  <div class="stat-card <%= bannedIPs>0?'danger':'success' %>"><div class="stat-label">IPs Banned</div><div class="stat-value"><%= bannedIPs %></div></div>
  <div class="stat-card <%= certIssues>0?'warning':'success' %>"><div class="stat-label">Certificate Issues</div><div class="stat-value"><%= certIssues %></div></div>
</div>
<% if(scap && scap.checks){%>
<div class="card"><div class="card-header"><span class="card-title">SCAP Detail</span></div><div class="card-body">
<table><thead><tr><th>Check</th><th>Result</th><th>Detail</th></tr></thead><tbody>
<% for(var i=0;i<scap.checks.length;i++){var c=scap.checks[i];%>
<tr><td style="font-size:12px;font-weight:500;"><%= c.name %></td><td><span class="badge <%= c.pass?'badge-active':'badge-disabled' %>"><%= c.pass?'PASS':'FAIL' %></span></td><td class="text-muted" style="font-size:11px;"><%= c.detail %></td></tr>
<%}%>
</tbody></table>
</div></div>
<%}%>
</div>
<%- include('../layout-end') %>