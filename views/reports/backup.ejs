<%- include('../layout', { title: 'Backup Report', page: 'reports', admin }) %>
<div class="topbar"><div><div class="topbar-title">Backup Report</div><div class="topbar-sub"><%= history.length %> backup records</div></div>
<div class="topbar-actions"><a href="/reports/export/backup" class="btn btn-primary">Export CSV</a><a href="/backup" class="btn btn-secondary">Manage Backups</a><a href="/reports" class="btn btn-secondary">Back</a></div></div>
<div class="content">
<% var completed=history.filter(function(b){return b.status==='completed';});var failed=history.filter(function(b){return b.status==='failed';});%>
<div class="stat-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:14px;">
  <div class="stat-card success"><div class="stat-label">Completed</div><div class="stat-value"><%= completed.length %></div></div>
  <div class="stat-card danger"><div class="stat-label">Failed</div><div class="stat-value"><%= failed.length %></div></div>
  <div class="stat-card"><div class="stat-label">Total</div><div class="stat-value" style="color:var(--text)"><%= history.length %></div></div>
</div>
<div class="card"><div class="card-body">
<table><thead><tr><th>Type</th><th>Status</th><th>Destination</th><th>Started</th><th>Completed</th></tr></thead><tbody>
<% for(var i=0;i<history.length;i++){var b=history[i];%>
<tr>
  <td class="mono" style="font-size:11px;"><%= b.type %></td>
  <td><span class="badge <%= b.status==='completed'?'badge-active':b.status==='running'?'badge-info':'badge-disabled' %>"><%= b.status %></span></td>
  <td class="mono text-muted" style="font-size:11px;"><%= b.destination||'—' %></td>
  <td class="text-muted" style="font-size:11px;"><%= new Date(b.timestamp).toLocaleString() %></td>
  <td class="text-muted" style="font-size:11px;"><%= b.completedAt?new Date(b.completedAt).toLocaleString():'—' %></td>
</tr>
<%}%>
</tbody></table>
</div></div></div>
<%- include('../layout-end') %>