<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Error | AD Console</title>
<style>*{box-sizing:border-box;margin:0;padding:0}body{font-family:system-ui,sans-serif;background:#0f1117;color:#e2e8f0;min-height:100vh;display:flex;align-items:center;justify-content:center;}
.box{text-align:center;padding:40px;}.code{font-size:80px;font-weight:200;color:#4f8ef7;line-height:1;}.msg{font-size:16px;color:#94a3b8;margin:16px 0;}.btn{display:inline-block;padding:10px 20px;background:#4f8ef7;color:#fff;border-radius:8px;text-decoration:none;font-size:14px;margin-top:16px;}</style></head>
<body><div class="box"><div class="code"><%= code %></div><div class="msg"><%= message %></div>
<% if (admin) { %><a href="/dashboard" class="btn">Back to Dashboard</a><% } else { %><a href="/login" class="btn">Go to Login</a><% } %>
</div></body></html>