<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Sign In | AD Web Console</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#070a0f;--surface:#0d1117;--surface2:#161b27;--border:#1e2535;--border2:#2a3348;
  --primary:#4f8ef7;--primary-dark:#3a75e0;--primary-glow:rgba(79,142,247,.15);--primary-bright:rgba(79,142,247,.35);
  --success:#10b981;--success-bg:rgba(16,185,129,.1);--danger:#ef4444;--danger-bg:rgba(239,68,68,.1);
  --info:#60a5fa;--info-bg:rgba(96,165,250,.1);--warning:#f59e0b;--warning-bg:rgba(245,158,11,.1);
  --text:#f1f5f9;--text2:#94a3b8;--text3:#475569;--mono:'JetBrains Mono',monospace;--sans:'Inter',system-ui,sans-serif;--radius:8px;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1rem;position:relative;overflow:hidden;}
/* Background grid */
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(79,142,247,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(79,142,247,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;}
/* Glow orbs */
.orb{position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;z-index:0;}
.orb1{width:400px;height:400px;background:rgba(79,142,247,.08);top:-100px;right:-100px;}
.orb2{width:300px;height:300px;background:rgba(99,102,241,.06);bottom:-50px;left:-50px;}
.wrap{width:100%;max-width:400px;position:relative;z-index:1;}
.logo-block{text-align:center;margin-bottom:28px;animation:fadeSlide .5s ease both;}
.logo-icon{width:56px;height:56px;background:linear-gradient(135deg,var(--primary),#6366f1);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;box-shadow:0 0 32px var(--primary-glow),0 4px 16px rgba(0,0,0,.3);}
.logo-icon svg{width:28px;height:28px;fill:white;}
.logo-title{font-size:22px;font-weight:700;letter-spacing:-.04em;background:linear-gradient(135deg,#fff,#94a3b8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.logo-sub{font-size:11px;color:var(--text3);font-family:var(--mono);margin-top:4px;}
.card{background:var(--surface);border:1px solid var(--border2);border-radius:16px;padding:28px;box-shadow:0 8px 48px rgba(0,0,0,.4);animation:fadeSlide .5s ease .1s both;}
h2{font-size:15px;font-weight:700;margin-bottom:3px;letter-spacing:-.02em;}
.card-sub{font-size:12px;color:var(--text3);margin-bottom:20px;}
label{font-size:12px;font-weight:600;color:var(--text2);display:block;margin-bottom:5px;}
.form-group{margin-bottom:14px;position:relative;}
input{width:100%;background:var(--surface2);border:1px solid var(--border2);border-radius:var(--radius);color:var(--text);font-family:var(--sans);font-size:13px;padding:10px 13px;outline:none;transition:all .2s;}
input:focus{border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-glow);}
.btn{display:flex;align-items:center;justify-content:center;width:100%;height:44px;background:var(--primary);color:#fff;border:none;border-radius:var(--radius);font-size:13px;font-weight:700;font-family:var(--sans);cursor:pointer;transition:all .2s;margin-top:6px;letter-spacing:-.01em;box-shadow:0 0 20px var(--primary-glow);}
.btn:hover{background:var(--primary-dark);box-shadow:0 0 32px var(--primary-bright);}
.btn:active{transform:scale(.99);}
.alert{padding:10px 13px;border-radius:var(--radius);font-size:12px;margin-bottom:14px;border:1px solid;}
.alert-error{background:var(--danger-bg);color:var(--danger);border-color:rgba(239,68,68,.3);}
.alert-success{background:var(--success-bg);color:var(--success);border-color:rgba(16,185,129,.3);}
.info-boxes{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:20px;}
.info-box{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:12px;}
.info-box-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;margin-bottom:7px;display:flex;align-items:center;gap:5px;}
.dot{width:7px;height:7px;border-radius:50%;box-shadow:0 0 6px currentColor;}
.dot-admin{color:var(--warning);}
.dot-user{color:var(--success);}
.admin-c{color:var(--warning);}
.user-c{color:var(--success);}
.info-box li{font-size:11px;color:var(--text2);padding:2px 0;list-style:none;display:flex;align-items:center;gap:5px;}
.info-box li::before{content:'';width:4px;height:4px;border-radius:50%;background:var(--text3);flex-shrink:0;}
.footer{text-align:center;font-size:11px;color:var(--text3);margin-top:18px;animation:fadeSlide .5s ease .3s both;}
.footer span{background:var(--surface);border:1px solid var(--border);padding:3px 10px;border-radius:6px;}
@keyframes fadeSlide{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
.btn-loading::after{content:'';width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;margin-left:8px;}
</style>
</head>
<body>
<div class="orb orb1"></div>
<div class="orb orb2"></div>
<div class="wrap">
  <div class="logo-block">
    <div class="logo-icon">
      <svg viewBox="0 0 20 20"><path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm0 6a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2zm0 6a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1v-2z"/></svg>
    </div>
    <div class="logo-title">AD Web Console</div>
    <div class="logo-sub"><%= domain %></div>
  </div>

  <div class="card">
    <h2>Welcome back</h2>
    <p class="card-sub">Sign in with your domain credentials</p>

    <% if(typeof error !== 'undefined' && error){%><div class="alert alert-error"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-right:5px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><%= error %></div><%}%>
    <% if(typeof info !== 'undefined' && info){%><div class="alert alert-success"><%= info %></div><%}%>

    <form method="POST" action="/login" autocomplete="off" id="loginForm">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="administrator or domain\user" autofocus autocomplete="username" required/>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="Domain password" autocomplete="current-password" required/>
      </div>
      <button type="submit" class="btn" id="loginBtn">Sign In</button>
    </form>

    <div class="info-boxes">
      <div class="info-box">
        <div class="info-box-title admin-c"><div class="dot dot-admin" style="background:var(--warning);"></div>Admin Portal</div>
        <ul>
          <li>Manage users &amp; groups</li>
          <li>Reset passwords</li>
          <li>Manage computers</li>
          <li>Create &amp; link GPOs</li>
          <li>DC Migration center</li>
          <li>SCAP security score</li>
        </ul>
      </div>
      <div class="info-box">
        <div class="info-box-title user-c"><div class="dot dot-user" style="background:var(--success);"></div>User Portal</div>
        <ul>
          <li>View own profile</li>
          <li>Change password</li>
          <li>View my groups</li>
          <li>View applied GPOs</li>
          <li>View backup status</li>
          <li>Domain info</li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer"><span>Authorized access only &mdash; All actions are audited</span></div>
</div>
<script>
document.getElementById('loginForm').addEventListener('submit',function(){
  var btn=document.getElementById('loginBtn');
  btn.textContent='Signing in...';
  btn.classList.add('btn-loading');
  btn.style.pointerEvents='none';
});
</script>
</body></html>
