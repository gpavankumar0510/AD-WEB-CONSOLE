<%- include('../layout', { title: 'DC Migration', page: 'migration', admin }) %>
<div class="topbar"><div><div class="topbar-title">DC Migration Center</div><div class="topbar-sub">Centralized Domain Controller migration management</div></div><div class="topbar-actions"><a href="/migration/assess" class="btn btn-warning">Pre-Migration Assessment</a><a href="/migration/new" class="btn btn-primary">New Migration Job</a></div></div>
<div class="content">
<% var runJ=0,compJ=0,failJ=0,pendJ=0;jobs.forEach(function(j){if(j.status==='running')runJ++;else if(j.status==='completed')compJ++;else if(j.status==='failed')failJ++;else if(j.status==='pending')pendJ++;});%>
<div class="stat-grid" style="grid-template-columns:repeat(5,1fr);margin-bottom:14px;">
  <div class="stat-card"><div class="stat-label">Total Jobs</div><div class="stat-value" style="color:var(--text)"><%= jobs.length %></div></div>
  <div class="stat-card info"><div class="stat-label">Running</div><div class="stat-value"><%= runJ %></div></div>
  <div class="stat-card success"><div class="stat-label">Completed</div><div class="stat-value"><%= compJ %></div></div>
  <div class="stat-card danger"><div class="stat-label">Failed</div><div class="stat-value"><%= failJ %></div></div>
  <div class="stat-card warning"><div class="stat-label">Pending</div><div class="stat-value"><%= pendJ %></div></div>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;">
  <div class="card"><div class="card-header"><span class="card-title">Supported Migration Scenarios</span></div><div class="card-body" style="padding:0;">
    <% var scenarios=[{id:'DC-to-DC',icon:'🖥️',label:'DC to DC',desc:'Migrate between Windows Server versions (2016→2019→2022→2025)'},{id:'P2V',icon:'☁️',label:'Physical to Virtual',desc:'Convert physical DC to Hyper-V or VMware VM'},{id:'V2P',icon:'💻',label:'Virtual to Physical',desc:'Move VM-hosted DC back to physical hardware'},{id:'cloud',icon:'🌐',label:'On-Premises to Cloud',desc:'Migrate to Azure AD DS or hybrid with AD Connect'}];%>
    <% for(var sci=0;sci<scenarios.length;sci++){var sc=scenarios[sci];%>
    <div style="display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);">
      <div style="font-size:20px;flex-shrink:0;"><%= sc.icon %></div>
      <div style="flex:1;"><div style="font-size:13px;font-weight:500;"><%= sc.label %></div><div style="font-size:11px;color:var(--text3);"><%= sc.desc %></div></div>
      <a href="/migration/new?scenario=<%= sc.id %>" class="btn btn-secondary btn-sm">Start</a>
    </div>
    <%}%>
  </div></div>
  <div class="card"><div class="card-header"><span class="card-title">Recent Assessments</span><div class="card-header-actions"><a href="/migration/assess" class="btn btn-warning btn-sm">New Assessment</a></div></div><div class="card-body">
    <% if(!assessments.length){%><div class="empty-state" style="padding:24px;"><p>No assessments yet. Run a pre-migration assessment first.</p><a href="/migration/assess" class="btn btn-warning btn-sm" style="margin-top:10px;">Run Assessment</a></div>
    <%}else{%><table><thead><tr><th>Date</th><th>Target OS</th><th>Readiness</th><th>Issues</th></tr></thead><tbody>
    <% for(var ai=0;ai<assessments.length&&ai<5;ai++){var a=assessments[ai];%>
    <tr><td class="text-muted" style="font-size:11px;"><%= new Date(a.timestamp).toLocaleString() %></td><td style="font-size:12px;">WS <%= a.targetOS %></td><td><span class="badge <%= a.readiness==='ready'?'badge-active':a.readiness==='ready-with-warnings'?'badge-locked':'badge-disabled' %>"><%= a.readiness %></span></td><td style="font-size:12px;color:<%= a.errors>0?'var(--danger)':'var(--success)' %>;"><%= a.errors %> errors</td></tr>
    <%}%></tbody></table><%}%>
  </div></div>
</div>
<div class="card"><div class="card-header"><span class="card-title">Migration Jobs</span></div><div class="card-body">
<% if(!jobs.length){%><div class="empty-state" style="padding:24px;"><p>No migration jobs yet.</p></div>
<%}else{%><table><thead><tr><th>Job Name</th><th>Scenario</th><th>Source</th><th>Target</th><th>Status</th><th>Progress</th><th>Created</th><th></th></tr></thead><tbody>
<% for(var ji=0;ji<jobs.length;ji++){var j=jobs[ji];%>
<tr>
  <td><a href="/migration/job/<%= j.id %>" style="color:var(--text);font-weight:500;font-size:13px;"><%= j.name %></a></td>
  <td><span class="badge badge-info" style="font-size:10px;"><%= j.scenario %></span></td>
  <td class="mono text-muted" style="font-size:11px;"><%= j.sourceServer||'—' %></td>
  <td class="mono text-muted" style="font-size:11px;"><%= j.targetServer||'—' %></td>
  <td><span class="badge <%= j.status==='completed'?'badge-active':j.status==='running'?'badge-info':j.status==='failed'?'badge-disabled':j.status==='cancelled'?'badge-locked':'badge-neutral' %>"><%= j.status %></span></td>
  <td style="min-width:80px;"><div style="height:5px;background:var(--border);border-radius:3px;overflow:hidden;"><div style="height:100%;background:<%= j.status==='completed'?'var(--success)':j.status==='failed'?'var(--danger)':'var(--primary)' %>;border-radius:3px;width:<%= j.progress||0 %>%;"></div></div><span style="font-size:10px;color:var(--text3);"><%= j.progress||0 %>%</span></td>
  <td class="text-muted" style="font-size:11px;"><%= new Date(j.createdAt).toLocaleDateString() %></td>
  <td><a href="/migration/job/<%= j.id %>" class="btn btn-secondary btn-sm">View</a></td>
</tr>
<%}%></tbody></table><%}%></div></div></div>
<%- include('../layout-end') %>