<%- include('../layout', { title: job.name, page: 'migration', admin }) %>
<style>
.step-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.step-pending{background:var(--surface3);color:var(--text3);}
.step-running{background:var(--info-bg);color:var(--info);animation:pulse 1.5s infinite;}
.step-done{background:var(--success-bg);color:var(--success);}
.step-error{background:var(--danger-bg);color:var(--danger);}
.step-warning{background:var(--warning-bg);color:var(--warning);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.log-entry{padding:4px 0;border-bottom:1px solid var(--border);font-size:11px;font-family:var(--mono);}
.log-success{color:var(--success);}.log-error{color:var(--danger);}.log-warning{color:var(--warning);}.log-running{color:var(--info);}.log-info{color:var(--text2);}
</style>
<div class="topbar"><div><div class="topbar-title"><%= job.name %></div><div class="topbar-sub"><%= job.scenario %> &mdash; Created <%= new Date(job.createdAt).toLocaleString() %></div></div>
<div class="topbar-actions" id="topActions">
  <% if(job.status==='pending'){%><button class="btn btn-primary" onclick="startJob()">▶ Start Migration</button><%}%>
  <% if(job.status==='running'){%><button class="btn btn-danger" onclick="cancelJob()">⛔ Cancel</button><%}%>
  <% if(job.status==='failed'||job.status==='completed'){%><button class="btn btn-warning" onclick="rollbackJob()">↩ Rollback</button><%}%>
  <a href="/migration" class="btn btn-secondary">Back</a>
</div></div>
<div class="content">
<div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;margin-bottom:14px;">
  <div style="display:flex;align-items:center;gap:16px;margin-bottom:8px;">
    <div><div style="font-size:11px;color:var(--text3);margin-bottom:3px;">Status</div><span class="badge <%= job.status==='completed'?'badge-active':job.status==='running'?'badge-info':job.status==='failed'?'badge-disabled':job.status==='cancelled'?'badge-locked':'badge-neutral' %>" id="statusBadge"><%= job.status %></span></div>
    <div style="flex:1;"><div style="font-size:11px;color:var(--text3);margin-bottom:3px;">Progress</div><div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden;"><div id="progressBar" style="height:100%;border-radius:4px;transition:width .5s;background:<%= job.status==='completed'?'var(--success)':job.status==='failed'?'var(--danger)':'var(--primary)' %>;width:<%= job.progress||0 %>%;"></div></div><div style="font-size:10px;color:var(--text3);margin-top:3px;" id="progressText"><%= job.progress||0 %>% — <span id="currentStep"><%= job.currentStep||'Pending' %></span></div></div>
    <div><div style="font-size:11px;color:var(--text3);margin-bottom:3px;">Server Info</div><div class="mono" style="font-size:11px;"><%= job.sourceServer||'—' %> → <%= job.targetServer||'—' %></div></div>
  </div>
</div>

<% if(job.cloudConfig){%>
<div class="card" style="margin-bottom:14px;">
  <div class="card-header">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--info)" stroke-width="2"><path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/></svg>
    <span class="card-title">Cloud Account Configuration</span>
  </div>
  <div class="card-body" style="padding:0 16px;">
    <div class="settings-row"><span class="text-muted" style="font-size:12px;">Provider</span><span style="font-size:12px;font-weight:500;"><%= job.cloudConfig.provider %></span></div>
    <div class="settings-row"><span class="text-muted" style="font-size:12px;">Tenant ID</span><span class="mono" style="font-size:11px;"><%= job.cloudConfig.tenantId||'—' %></span></div>
    <div class="settings-row"><span class="text-muted" style="font-size:12px;">Client ID</span><span class="mono" style="font-size:11px;"><%= job.cloudConfig.clientId||'—' %></span></div>
    <div class="settings-row"><span class="text-muted" style="font-size:12px;">Domain</span><span style="font-size:12px;"><%= job.cloudConfig.domain||'—' %></span></div>
    <div class="settings-row"><span class="text-muted" style="font-size:12px;">Client Secret</span><span class="badge <%= job.cloudConfig.clientSecretEnc?'badge-active':'badge-neutral' %>"><%= job.cloudConfig.clientSecretEnc?'Stored (encrypted)':'Not set' %></span></div>
    <div class="settings-row" style="border:none;"><span class="text-muted" style="font-size:12px;">Password Hash Sync</span><span class="badge <%= job.cloudConfig.syncPasswords?'badge-active':'badge-neutral' %>"><%= job.cloudConfig.syncPasswords?'Enabled':'Disabled' %></span></div>
  </div>
</div>
<%}%>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
  <div class="card"><div class="card-header"><span class="card-title">Migration Steps</span></div><div class="card-body" id="stepsContainer">
    <% for(var si=0;si<job.steps.length;si++){var st=job.steps[si];%>
    <div style="display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-bottom:1px solid var(--border);" id="step-<%= st.id %>">
      <div class="step-icon step-<%= st.status||'pending' %>"><%= st.status==='done'?'✓':st.status==='error'?'✗':st.status==='running'?'⟳':st.status==='warning'?'!':si+1 %></div>
      <div style="flex:1;min-width:0;"><div style="font-size:13px;font-weight:500;"><%= st.name %></div><% if(st.output){%><div style="font-size:11px;color:var(--text3);margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= st.output %>"><%= st.output.slice(0,80) %></div><%}%><% if(st.error){%><div style="font-size:11px;color:var(--danger);margin-top:2px;"><%= st.error %></div><%}%></div>
      <span class="badge <%= st.status==='done'?'badge-active':st.status==='error'?'badge-disabled':st.status==='running'?'badge-info':st.status==='warning'?'badge-locked':'badge-neutral' %>" style="font-size:10px;flex-shrink:0;"><%= st.status||'pending' %></span>
    </div>
    <%}%>
  </div></div>
  <div class="card"><div class="card-header"><span class="card-title">Audit Log</span></div><div id="logsContainer" style="max-height:380px;overflow-y:auto;padding:10px 14px;">
    <% var logs=job.logs||[];%>
    <% if(!logs.length){%><div class="empty-state" style="padding:16px;"><p>No logs yet. Start the job to see output.</p></div>
    <%}else{for(var li=0;li<logs.length;li++){var log=logs[li];%>
    <div class="log-entry log-<%= log.status %>"><span style="color:var(--text3);">[<%= new Date(log.time).toLocaleTimeString() %>]</span> <span style="font-weight:500;">[<%= log.step %>]</span> <span><%= (log.message||'').slice(0,200) %></span></div>
    <%}%>
    <%}%>
  </div></div>
</div></div>
<script>
var jobId='<%= job.id %>',pollInterval;
function startJob(){if(!confirm('Start migration job "<%- job.name %>"?\n\nEnsure you have a current backup before proceeding.'))return;fetch('/migration/job/'+jobId+'/start',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'}).then(function(r){return r.json();}).then(function(d){if(d.ok){startPolling();setTimeout(function(){location.reload();},500);}else alert('Error: '+d.error);});}
function cancelJob(){if(!confirm('Cancel this job?'))return;fetch('/migration/job/'+jobId+'/cancel',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'}).then(function(r){return r.json();}).then(function(d){if(d.ok)location.reload();else alert(d.error);});}
function rollbackJob(){if(!confirm('Initiate rollback?\n\nThis will generate rollback instructions and attempt restore from backup.'))return;var btn=event.target;btn.disabled=true;btn.textContent='Rolling back...';fetch('/migration/job/'+jobId+'/rollback',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'}).then(function(r){return r.json();}).then(function(d){if(d.ok){alert('Rollback initiated:\n\n'+(d.message||''));location.reload();}else{alert('Error: '+d.error);btn.disabled=false;btn.textContent='↩ Rollback';}});}
function startPolling(){if(pollInterval)clearInterval(pollInterval);pollInterval=setInterval(pollStatus,2000);}
function pollStatus(){fetch('/migration/job/'+jobId+'/status').then(function(r){return r.json();}).then(function(d){if(!d.ok)return;var bar=document.getElementById('progressBar');var txt=document.getElementById('progressText');var badge=document.getElementById('statusBadge');if(bar)bar.style.width=(d.progress||0)+'%';if(txt)txt.innerHTML=(d.progress||0)+'% — <span id="currentStep">'+(d.currentStep||'')+'</span>';if(badge)badge.textContent=d.status;if(d.steps)d.steps.forEach(function(st){var el=document.getElementById('step-'+st.id);if(el){var icon=el.querySelector('.step-icon');var bdg=el.querySelector('.badge');if(icon){icon.className='step-icon step-'+(st.status||'pending');icon.textContent=st.status==='done'?'✓':st.status==='error'?'✗':st.status==='running'?'⟳':'';}if(bdg)bdg.textContent=st.status||'pending';}});if(d.logs&&d.logs.length){var lc=document.getElementById('logsContainer');if(lc){var html='';d.logs.forEach(function(log){html+='<div class="log-entry log-'+log.status+'"><span style="color:var(--text3);">['+new Date(log.time).toLocaleTimeString()+']</span> <span style="font-weight:500;">['+log.step+']</span> <span>'+(log.message||'').slice(0,200)+'</span></div>';});lc.innerHTML=html;lc.scrollTop=lc.scrollHeight;}}if(d.status!=='running'){clearInterval(pollInterval);if(d.status==='completed'||d.status==='failed'||d.status==='cancelled')setTimeout(function(){location.reload();},1000);}}).catch(function(){});}
if('<%= job.status %>'==='running')startPolling();
</script>
<%- include('../layout-end') %>